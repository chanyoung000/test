const _SEED = 'constlaw2024kr';
const _GEMINI_K = '';
const _LAW_OC_K = '';

// --- 암호화 키 저장/로드 ---
function saveKeyEncrypted(type, value) {
    var storageKey = type === 'gemini' ? 'cl_gemini_key_enc' : 'cl_law_oc_enc';
    if (value) {
        localStorage.setItem(storageKey, _ek(value, _SEED));
    } else {
        localStorage.removeItem(storageKey);
    }
    // 이전 평문 키 삭제 (마이그레이션)
    localStorage.removeItem(type === 'gemini' ? 'cl_gemini_key' : 'cl_law_oc');
}

function loadKeyDecrypted(type) {
    var encKey = type === 'gemini' ? 'cl_gemini_key_enc' : 'cl_law_oc_enc';
    var plainKey = type === 'gemini' ? 'cl_gemini_key' : 'cl_law_oc';
    // 1순위: 암호화된 localStorage
    var enc = localStorage.getItem(encKey);
    if (enc) {
        try { return _dk(enc, _SEED); } catch (e) {}
    }
    // 2순위: 이전 평문 localStorage (자동 마이그레이션)
    var plain = localStorage.getItem(plainKey);
    if (plain) {
        saveKeyEncrypted(type, plain); // 암호화 재저장
        return plain;
    }
    return '';
}

function hasKeySaved(type) {
    var encKey = type === 'gemini' ? 'cl_gemini_key_enc' : 'cl_law_oc_enc';
    return !!localStorage.getItem(encKey);
}

function getGeminiKey() {
    var saved = loadKeyDecrypted('gemini');
    if (saved) return saved;
    // config.js 폴백
    if (window.__CL_CONFIG && window.__CL_CONFIG.GEMINI_KEY) return window.__CL_CONFIG.GEMINI_KEY;
    return '';
}

function getLawOC() {
    var saved = loadKeyDecrypted('law');
    if (saved) return saved;
    // config.js 폴백
    if (window.__CL_CONFIG && window.__CL_CONFIG.LAW_OC) return window.__CL_CONFIG.LAW_OC;
    return '';
