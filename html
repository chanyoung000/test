// 모델 폴백 체인: 한도 소진 시 다음 모델로 자동 전환
var GEMINI_MODEL_CHAIN = ['gemini-2.0-flash', 'gemini-2.0-flash-lite', 'gemini-2.5-flash'];
var GEMINI_MODEL = GEMINI_MODEL_CHAIN[0];
var _geminiModelIndex = 0; // 현재 사용 중인 모델 인덱스

async function callGeminiRaw(apiKey, prompt) {
    // 무료 한도 체크 (90% 상한)
    var check = canMakeAPICall();
    if (!check.ok) {
        throw new Error(check.reason);
    }

    var body = {
        contents: [{
            parts: [{ text: prompt }]
        }],
        generationConfig: {
            temperature: 0.3,
            maxOutputTokens: 8192
        }
    };

    // 모델 폴백 체인 순회
    var startModelIndex = _geminiModelIndex;
    for (var mi = startModelIndex; mi < GEMINI_MODEL_CHAIN.length; mi++) {
        var currentModel = GEMINI_MODEL_CHAIN[mi];
        var url = 'https://generativelanguage.googleapis.com/v1beta/models/' + currentModel + ':generateContent?key=' + apiKey;

        // 각 모델에 대해 최대 2회 재시도
        var maxRetries = 2;
        for (var attempt = 0; attempt <= maxRetries; attempt++) {
            var resp = await fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body)
            });

            if (resp.ok) {
                // 성공: 사용량 기록 + 현재 모델 기억
                recordAPICall();
                _geminiModelIndex = mi;
                GEMINI_MODEL = currentModel;
                var data = await resp.json();
                if (data.candidates && data.candidates[0] && data.candidates[0].content && data.candidates[0].content.parts) {
                    return data.candidates[0].content.parts[0].text;
                }
                throw new Error('Gemini API 응답 형식 오류');
            }

            if (resp.status === 429) {
                var errText429 = await resp.text();
                var isDailyExhausted = false;
                var retryAfterSec = 20; // 기본 대기 시간
                try {
                    var errData429 = JSON.parse(errText429);
                    var errMsg429 = errData429.error ? errData429.error.message : '';
                    // API가 알려주는 재시도 시간 파싱 (예: "retry in 16.642803062s")
                    var retryMatch = errMsg429.match(/retry\s+in\s+([\d.]+)s/i);
                    if (retryMatch) {
                        var parsedSec = parseFloat(retryMatch[1]);
                        retryAfterSec = Math.ceil(parsedSec) + 2; // 여유 2초 추가
                        // 재시도 시간이 300초(5분) 이상이면 일일 한도 소진으로 판단
                        if (parsedSec > 300) {
                            isDailyExhausted = true;
                        }
                    }
                    // "limit: 0"이고 재시도 시간이 없거나 매우 길면 일일 한도 소진
                    if (errMsg429.indexOf('limit: 0') !== -1 && !retryMatch) {
                        isDailyExhausted = true;
                    }
                } catch (pe) { /* 파싱 실패 시 기본값 사용 */ }

                // 일일 한도 확실히 소진: 이 모델 포기 → 다음 모델로
                if (isDailyExhausted) {
                    console.warn('Gemini ' + currentModel + ' 일일 한도 소진, 다음 모델로 전환');
                    break; // 내부 retry 루프 탈출 → 다음 모델 시도
                }

                // 일시적 한도 (분당/limit:0 + retry 시간 짧음): 대기 후 재시도
                if (attempt < maxRetries) {
                    var waitMs = retryAfterSec * 1000;
                    console.warn('Gemini ' + currentModel + ' 429 (일시적 한도), ' + retryAfterSec + '초 후 재시도 (' + (attempt + 1) + '/' + maxRetries + ')');
                    await new Promise(function(resolve) { setTimeout(resolve, waitMs); });
                    continue;
                }

                // 재시도 모두 소진 → 다음 모델로 전환
                console.warn('Gemini ' + currentModel + ' 429 재시도 소진, 다음 모델로 전환');
                break; // 내부 retry 루프 탈출 → 다음 모델 시도
            }

            // 429가 아닌 다른 에러: 즉시 throw (다음 모델로 넘기지 않음)
            var errText = await resp.text();
            var errMsg = '알 수 없는 오류';
            try {
                var errData = JSON.parse(errText);
                errMsg = errData.error ? errData.error.message : errText;
            } catch (pe) {
                errMsg = errText;
            }
            throw new Error('Gemini API 오류 (' + resp.status + ', ' + currentModel + '): ' + errMsg);
        }
    }

    // 모든 모델 소진
    throw new Error('Gemini API 모든 모델의 일일 한도가 소진되었습니다. (' + GEMINI_MODEL_CHAIN.join(', ') + ')\n내일 한도가 초기화된 후 다시 시도해주세요.');
}

async function callAI(systemPrompt, userMessage) {
    var key = getGeminiKey();
    if (!key) throw new Error('Gemini API 키가 설정되지 않았습니다. 설정에서 API 키를 입력하세요.');

    var combinedPrompt = systemPrompt + '\n\n사용자 질문:\n' + userMessage;
    return callGeminiRaw(key, combinedPrompt);
}

// Phase 1: 질문 심층 분석 + 드래프트 답변 생성
async function analyzeQuestion(question) {
    var systemPrompt = '당신은 한국 법률 전문 AI입니다. 사용자의 법률 질문을 심층 분석하고, 드래프트 답변을 작성하세요.\n\n' +
