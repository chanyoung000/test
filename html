var isSearching = false;

async function performSearch() {
    if (isSearching) return;

    var question = document.getElementById('searchInput').value.trim();
    if (!question) {
        showToast('질문을 입력해주세요');
        document.getElementById('searchInput').focus();
        return;
    }

    var geminiKey = getGeminiKey();
    if (!geminiKey) {
        showToast('Gemini API 키가 필요합니다. 설정에서 입력하세요.', 3500);
        openSettings();
        return;
    }

    isSearching = true;
    document.getElementById('btnSearch').disabled = true;

    // UI 초기화
    showProgress();
    hideResponse();
    hideLawRefs();
    hideFollowUp();
    document.getElementById('directResults').classList.remove('show');

    var lawDataCollection = [];
    var analysisResult = null;
    var hasLawAPI = !!getLawOC();
    var searchStats = { law: 0, admrul: 0, ordin: 0, prec: 0, expc: 0, detc: 0, decc: 0 };

    try {
        // ========== Phase 1: AI 질문 심층 분석 ==========
        updateProgress(1, 'AI가 질문을 심층 분석하고 있습니다...');
        try {
            analysisResult = await analyzeQuestion(question);
        } catch (aiError) {
            console.warn('AI 분석 실패:', aiError.message);
            analysisResult = {
                draftAnswer: '',
                citations: [],
                searchStrategy: {
                    lawTitle: [], lawContent: [question], admrul: [], ordin: [],
                    precContent: [question], precRefLaw: [], expc: [question]
                },
                needsDetc: false, needsDecc: false,
                detcKeywords: [], deccKeywords: [],
                followUpQuestions: [],
                relevantLaws: [],
                searchKeywords: [question],
                specificArticles: [],
                reasoning: 'AI 분석 실패, 직접 검색'
            };
        }

        // ========== Phase 2 Wave 1: 병렬 검색 ==========
        updateProgress(2, '법령·판례·질의회신을 검색하고 있습니다...');

        if (hasLawAPI) {
            var wave1Promises = [];
            var strategy = analysisResult.searchStrategy || {};

            // --- lstrmAI 키워드 확장 (최대 3개) ---
            var lstrmKws = (strategy.lawContent || []).slice(0, 3);
            lstrmKws.forEach(function(kw) {
                wave1Promises.push(
                    searchLstrmAI(kw)
                        .then(function(terms) { return { type: 'lstrm', keyword: kw, terms: terms }; })
                        .catch(function() { return { type: 'lstrm', keyword: kw, terms: [kw] }; })
                );
            });

            // --- 법령 제목검색 (search=1, 최대 5kw, display=20) ---
            var lawTitleKws = (strategy.lawTitle || []).slice(0, 5);
            if (lawTitleKws.length === 0 && analysisResult.relevantLaws) {
                lawTitleKws = analysisResult.relevantLaws.slice(0, 5);
            }
            if (lawTitleKws.length === 0) {
                lawTitleKws = [question.substring(0, 20)];
            }
            lawTitleKws.forEach(function(kw) {
                wave1Promises.push(
                    searchLaw(kw, 'law', 1, { search: 1, display: 20 })
                        .then(function(r) { return { type: 'lawTitle', keyword: kw, searchResults: r.items, totalCount: r.totalCount }; })
                        .catch(function(err) { console.warn('법령 제목검색 "' + kw + '" 실패:', err.message); return { type: 'lawTitle', keyword: kw, searchResults: [], totalCount: 0 }; })
                );
            });

            // --- 법령 본문검색 (search=2, 최대 3kw, display=20) ---
            var lawContentKws = (strategy.lawContent || []).slice(0, 3);
            lawContentKws.forEach(function(kw) {
                wave1Promises.push(
                    searchLaw(kw, 'law', 1, { search: 2, display: 20 })
                        .then(function(r) { return { type: 'lawContent', keyword: kw, searchResults: r.items, totalCount: r.totalCount }; })
                        .catch(function(err) { console.warn('법령 본문검색 "' + kw + '" 실패:', err.message); return { type: 'lawContent', keyword: kw, searchResults: [], totalCount: 0 }; })
                );
            });

            // --- 행정규칙 본문검색 (search=2, 최대 2kw) ---
            var admrulKws = (strategy.admrul || []).slice(0, 2);
            if (admrulKws.length === 0) admrulKws = (strategy.lawContent || lawTitleKws).slice(0, 1);
            admrulKws.forEach(function(kw) {
                wave1Promises.push(
                    searchLaw(kw, 'admrul', 1, { search: 2 })
                        .then(function(r) { return { type: 'admrul', keyword: kw, searchResults: r.items, totalCount: r.totalCount, searchTarget: 'admrul' }; })
                        .catch(function() { return { type: 'admrul', keyword: kw, searchResults: [], totalCount: 0, searchTarget: 'admrul' }; })
                );
            });

            // --- 조례 본문검색 (search=2, 최대 2kw) ---
            var ordinKws = (strategy.ordin || []).slice(0, 2);
            if (ordinKws.length === 0) ordinKws = (strategy.lawContent || lawTitleKws).slice(0, 1);
            ordinKws.forEach(function(kw) {
                wave1Promises.push(
                    searchLaw(kw, 'ordin', 1, { search: 2 })
                        .then(function(r) { return { type: 'ordin', keyword: kw, searchResults: r.items, totalCount: r.totalCount, searchTarget: 'ordin' }; })
                        .catch(function() { return { type: 'ordin', keyword: kw, searchResults: [], totalCount: 0, searchTarget: 'ordin' }; })
                );
            });

            // --- 판례 본문검색 (search=2, 최대 3kw) ---
            var precContentKws = (strategy.precContent || []).slice(0, 3);
            precContentKws.forEach(function(kw) {
                wave1Promises.push(
                    searchPrec(kw, 1, { search: 2 })
                        .then(function(r) { return { type: 'prec', keyword: kw, items: r.items, totalCount: r.totalCount }; })
                        .catch(function() { return { type: 'prec', keyword: kw, items: [], totalCount: 0 }; })
                );
            });

            // --- 판례 JO검색 (참조법령, 최대 2개) ---
            var precRefLawKws = (strategy.precRefLaw || []).slice(0, 2);
            precRefLawKws.forEach(function(kw) {
                wave1Promises.push(
                    searchPrec(kw, 1, { JO: kw })
                        .then(function(r) { return { type: 'precJO', keyword: kw, items: r.items, totalCount: r.totalCount }; })
                        .catch(function() { return { type: 'precJO', keyword: kw, items: [], totalCount: 0 }; })
                );
            });

            // --- 질의회신 본문검색 (search=2, 최대 2kw) ---
            var expcKws = (strategy.expc || []).slice(0, 2);
            expcKws.forEach(function(kw) {
                wave1Promises.push(
                    searchExpc(kw, 1, { search: 2 })
                        .then(function(r) { return { type: 'expc', keyword: kw, items: r.items, totalCount: r.totalCount }; })
                        .catch(function() { return { type: 'expc', keyword: kw, items: [], totalCount: 0 }; })
                );
            });

            // --- 헌재결정례 (needsDetc=true일 때만) ---
            if (analysisResult.needsDetc) {
                var detcKws = (analysisResult.detcKeywords || []).slice(0, 2);
                if (detcKws.length === 0) detcKws = [question.substring(0, 15)];
                detcKws.forEach(function(kw) {
                    wave1Promises.push(
                        searchDetc(kw, 1, { search: 2 })
                            .then(function(r) { return { type: 'detc', keyword: kw, items: r.items, totalCount: r.totalCount }; })
                            .catch(function() { return { type: 'detc', keyword: kw, items: [], totalCount: 0 }; })
                    );
                });
            }

            // --- 행정심판재결례 (needsDecc=true일 때만) ---
            if (analysisResult.needsDecc) {
                var deccKws = (analysisResult.deccKeywords || []).slice(0, 2);
                if (deccKws.length === 0) deccKws = [question.substring(0, 15)];
                deccKws.forEach(function(kw) {
                    wave1Promises.push(
                        searchDecc(kw, 1, { search: 2 })
                            .then(function(r) { return { type: 'decc', keyword: kw, items: r.items, totalCount: r.totalCount }; })
                            .catch(function() { return { type: 'decc', keyword: kw, items: [], totalCount: 0 }; })
                    );
                });
            }

            // Wave 1 실행
            var wave1Results = await Promise.all(wave1Promises);

            // Wave 1 결과 수집
            var precItems = [];
            var expcItems = [];
            var detcItems = [];
            var deccItems = [];
            var lstrmExpandedTerms = [];
            var seenLawNames = {};
            var seenAdmrulNames = {};
            var seenOrdinNames = {};

            wave1Results.forEach(function(r) {
                // lstrmAI 확장 용어 수집
                if (r.type === 'lstrm') {
                    if (r.terms && r.terms.length > 0) {
                        r.terms.forEach(function(t) {
                            if (lstrmExpandedTerms.indexOf(t) === -1) lstrmExpandedTerms.push(t);
                        });
                    }
                } else if (r.type === 'lawTitle' || r.type === 'lawContent') {
                    if (r.searchResults && r.searchResults.length > 0) {
                        r.searchResults.forEach(function(sr) {
                            if (sr.lawName && !seenLawNames[sr.lawName]) seenLawNames[sr.lawName] = true;
                        });
                        lawDataCollection.push({ keyword: r.keyword, searchResults: r.searchResults, totalCount: r.totalCount });
                    }
                } else if (r.type === 'admrul') {
                    if (r.searchResults && r.searchResults.length > 0) {
                        r.searchResults.forEach(function(sr) {
                            if (sr.lawName && !seenAdmrulNames[sr.lawName]) seenAdmrulNames[sr.lawName] = true;
                        });
                        lawDataCollection.push({ keyword: r.keyword, searchResults: r.searchResults, totalCount: r.totalCount, searchTarget: 'admrul' });
                    }
                } else if (r.type === 'ordin') {
                    if (r.searchResults && r.searchResults.length > 0) {
                        r.searchResults.forEach(function(sr) {
                            if (sr.lawName && !seenOrdinNames[sr.lawName]) seenOrdinNames[sr.lawName] = true;
                        });
                        lawDataCollection.push({ keyword: r.keyword, searchResults: r.searchResults, totalCount: r.totalCount, searchTarget: 'ordin' });
                    }
                } else if (r.type === 'prec' || r.type === 'precJO') {
                    if (r.items) {
                        r.items.forEach(function(item) {
                            if (!precItems.find(function(p) { return p.id === item.id; })) {
                                precItems.push(item);
                            }
                        });
                    }
                } else if (r.type === 'expc') {
                    if (r.items) {
                        r.items.forEach(function(item) {
                            if (!expcItems.find(function(p) { return p.id === item.id; })) {
                                expcItems.push(item);
                            }
                        });
                    }
                } else if (r.type === 'detc') {
                    if (r.items) {
                        r.items.forEach(function(item) {
                            if (!detcItems.find(function(p) { return p.id === item.id; })) {
                                detcItems.push(item);
                            }
                        });
                    }
                } else if (r.type === 'decc') {
                    if (r.items) {
                        r.items.forEach(function(item) {
                            if (!deccItems.find(function(p) { return p.id === item.id; })) {
                                deccItems.push(item);
                            }
                        });
                    }
                }
            });

            // searchStats: 중복 제거된 고유 건수
            searchStats.law = Object.keys(seenLawNames).length;
            searchStats.admrul = Object.keys(seenAdmrulNames).length;
            searchStats.ordin = Object.keys(seenOrdinNames).length;

            // lstrmAI 확장 용어로 추가 법령 검색 (기존 키워드와 겹치지 않는 것만)
            var existingKws = [].concat(lawTitleKws, lawContentKws);
            var newLstrmKws = lstrmExpandedTerms.filter(function(t) {
                return existingKws.indexOf(t) === -1;
            }).slice(0, 3);
            if (newLstrmKws.length > 0) {
                var lstrmSearchPromises = newLstrmKws.map(function(kw) {
                    return searchLaw(kw, 'law', 1, { search: 2, display: 10 })
                        .then(function(r) {
                            if (r.items.length > 0) {
                                r.items.forEach(function(sr) {
                                    if (sr.lawName && !seenLawNames[sr.lawName]) {
                                        seenLawNames[sr.lawName] = true;
                                        searchStats.law++;
                                    }
                                });
                                lawDataCollection.push({ keyword: kw, searchResults: r.items, totalCount: r.totalCount });
                            }
                        })
                        .catch(function() {});
                });
                await Promise.all(lstrmSearchPromises);
            }

            // ========== Phase 2 Wave 2: 상세조회 + 인용 검증 ==========
            updateProgress(3, 'API 데이터를 검증하고 있습니다...');

            var wave2Promises = [];

            // AI 인용 조문 원문 검증 (citations 기반 getLawDetail) — 법령 + 조례 모두 포함
            if (analysisResult.citations && analysisResult.citations.length > 0) {
                var lawCitations = analysisResult.citations
                    .filter(function(c) { return (c.type === 'law' || c.type === 'ordin' || c.type === 'admrul') && c.name; })
                    .slice(0, 5);
                var seenLawNames = {};
                lawCitations.forEach(function(citation) {
                    if (seenLawNames[citation.name]) return;
                    seenLawNames[citation.name] = true;
                    var searchTarget = citation.type === 'ordin' ? 'ordin' : (citation.type === 'admrul' ? 'admrul' : 'law');
                    wave2Promises.push(
                        searchLaw(citation.name, searchTarget, 1)
                            .then(function(result) {
                                if (result.items.length > 0 && result.items[0].mst) {
                                    return getLawDetail(result.items[0].mst, searchTarget)
                                        .then(function(detail) {
                                            if (citation.article) {
                                                var numStr = String(citation.article).replace(/[^0-9]/g, '');
                                                var filtered = detail.articles.filter(function(a) {
                                                    return a.articleNum && a.articleNum.replace(/[^0-9]/g, '') === numStr;
                                                });
                                                if (filtered.length > 0) {
                                                    detail.articles = filtered;
                                                } else {
                                                    detail.articles = detail.articles.slice(0, 5);
                                                }
                                            } else {
                                                detail.articles = detail.articles.slice(0, 5);
                                            }
                                            return { type: 'lawDetail', data: detail };
                                        });
                                }
                                return null;
                            })
                            .catch(function(err) { console.warn('인용 검증 실패:', err.message); return null; })
                    );
                });
            }

            // 특정 조문 상세 조회 (specificArticles)
            if (analysisResult.specificArticles && analysisResult.specificArticles.length > 0) {
                analysisResult.specificArticles.slice(0, 3).forEach(function(spec) {
                    var allLaws = LAW_DATABASE.getAllLaws();
                    var foundLaw = allLaws.find(function(l) {
                        return l.name === spec.law || l.shortName === spec.law;
                    });
                    var searchName = foundLaw ? foundLaw.name : spec.law;

                    wave2Promises.push(
                        searchLaw(searchName, 'law', 1)
                            .then(function(result) {
                                if (result.items.length > 0 && result.items[0].mst) {
                                    return getLawDetail(result.items[0].mst)
                                        .then(function(detail) {
                                            if (spec.article) {
                                                var numStr = String(spec.article).replace(/[^0-9]/g, '');
                                                var filtered = detail.articles.filter(function(a) {
                                                    return a.articleNum && a.articleNum.replace(/[^0-9]/g, '') === numStr;
                                                });
                                                if (filtered.length > 0) detail.articles = filtered;
                                                else detail.articles = detail.articles.slice(0, 5);
                                            } else {
                                                detail.articles = detail.articles.slice(0, 5);
                                            }
                                            return { type: 'lawDetail', data: detail };
                                        });
                                }
                                return null;
                            })
                            .catch(function(err) { console.warn('상세 조회 실패:', err.message); return null; })
                    );
                });
            }

            // 행정규칙/조례 검색 결과 상위 2건씩 조문 상세조회
            var detailSeenMst = {};
            lawDataCollection.forEach(function(item) {
                if (!item.searchResults || !item.searchTarget) return;
                if (item.searchTarget !== 'admrul' && item.searchTarget !== 'ordin') return;
                var targetForDetail = item.searchTarget;
                item.searchResults.slice(0, 2).forEach(function(sr) {
                    var detailId = sr.mst || sr.lawId;
                    if (!detailId || detailSeenMst[detailId]) return;
                    detailSeenMst[detailId] = true;
                    wave2Promises.push(
                        getLawDetail(detailId, targetForDetail)
                            .then(function(detail) {
                                if (detail && detail.articles) {
                                    detail.articles = detail.articles.slice(0, 10);
                                }
                                return { type: 'lawDetail', data: detail };
                            })
                            .catch(function(err) { console.warn('행정규칙/조례 상세조회 실패:', err.message); return null; })
                    );
                });
            });

            // 법령 검색 결과 중 상위 3건 조문 상세조회 (AI 인용 외 추가)
            var lawDetailCount = 0;
            lawDataCollection.forEach(function(item) {
                if (!item.searchResults || item.searchTarget) return; // 법령만 (admrul/ordin 아님)
                item.searchResults.forEach(function(sr) {
                    var srId = sr.mst || sr.lawId;
                    if (lawDetailCount >= 3 || !srId || detailSeenMst[srId]) return;
                    detailSeenMst[srId] = true;
                    lawDetailCount++;
                    wave2Promises.push(
                        getLawDetail(srId)
                            .then(function(detail) {
                                if (detail && detail.articles) {
                                    detail.articles = detail.articles.slice(0, 10);
                                }
                                return { type: 'lawDetail', data: detail };
                            })
                            .catch(function(err) { console.warn('법령 상세조회 실패:', err.message); return null; })
                    );
                });
            });

            // 판례 상위 3건 상세조회
            precItems.slice(0, 3).forEach(function(item) {
                wave2Promises.push(
                    getPrecDetail(item.id)
                        .then(function(d) { return { type: 'precDetail', data: d }; })
                        .catch(function() { return null; })
                );
            });
            searchStats.prec = precItems.length;

            // 질의회신 상위 3건 상세조회
            expcItems.slice(0, 3).forEach(function(item) {
                wave2Promises.push(
                    getExpcDetail(item.id)
                        .then(function(d) { return { type: 'expcDetail', data: d }; })
                        .catch(function() { return null; })
                );
            });
            searchStats.expc = expcItems.length;

            // 헌재결정례 상위 3건 상세조회
            detcItems.slice(0, 3).forEach(function(item) {
                wave2Promises.push(
                    getDetcDetail(item.id)
                        .then(function(d) { return { type: 'detcDetail', data: d }; })
                        .catch(function() { return null; })
                );
            });
            searchStats.detc = detcItems.length;

            // 행정심판재결례 상위 3건 상세조회
            deccItems.slice(0, 3).forEach(function(item) {
                wave2Promises.push(
                    getDeccDetail(item.id)
                        .then(function(d) { return { type: 'deccDetail', data: d }; })
                        .catch(function() { return null; })
                );
            });
            searchStats.decc = deccItems.length;

            // Wave 2 실행
            var wave2Results = await Promise.all(wave2Promises);
            wave2Results.forEach(function(r) {
                if (!r || !r.data) return;
                if (r.type === 'lawDetail') lawDataCollection.push(r.data);
                else if (r.type === 'precDetail') lawDataCollection.push(r.data);
                else if (r.type === 'expcDetail') lawDataCollection.push(r.data);
                else if (r.type === 'detcDetail') lawDataCollection.push(r.data);
                else if (r.type === 'deccDetail') lawDataCollection.push(r.data);
            });
        }

        // ========== Phase 3: AI 통합 답변 ==========
        updateProgress(4, 'AI가 검증된 답변을 작성하고 있습니다...');
        var answer;
        try {
            answer = await synthesizeAnswer(question, lawDataCollection, analysisResult);
        } catch (aiError) {
            console.warn('AI 답변 실패:', aiError.message);
            // Phase 1 드래프트 답변을 미검증 표시로 사용
            if (analysisResult && analysisResult.draftAnswer) {
                answer = '## AI 분석 결과 (미검증)\n\n' +
                    '> **주의**: 이 답변은 API 검증을 거치지 않은 AI 초안입니다. 정확성을 보증하지 않습니다.\n\n' +
                    analysisResult.draftAnswer;
            } else if (lawDataCollection.length > 0) {
                answer = '## AI 답변 생성 실패\n\nAI 응답에 오류가 발생했습니다. 아래 검색된 법령 목록을 참고하세요.\n\n오류: ' + aiError.message;
            } else {
                throw aiError;
            }
        }

        // ========== 결과 표시 ==========
        hideProgress();
        displayAnswer(answer, question, searchStats);
        displayLawReferences(lawDataCollection);
        displayFollowUpQuestions(analysisResult);
        saveToHistory(question);

    } catch (error) {
        hideProgress();
        showError(error.message, question);
    } finally {
        isSearching = false;
        document.getElementById('btnSearch').disabled = false;
    }
}


