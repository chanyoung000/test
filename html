// =====================================================================
// Task 5: CORS 프록시 + 법령 API 통합
// =====================================================================
const CORS_PROXIES = [
    { url: 'https://corsproxy.io/?', type: 'prefix', healthy: true, latency: 9999 },
    { url: 'https://api.allorigins.win/raw?url=', type: 'allorigins', healthy: true, latency: 9999 },
    { url: 'https://cors.sh/?', type: 'prefix', healthy: true, latency: 9999 },
    { url: 'https://api.codetabs.com/v1/proxy?quest=', type: 'prefix', healthy: true, latency: 9999 }
];

var _localProxyAvailable = null;
var LOCAL_PROXY = 'http://127.0.0.1:18380';
// same-origin: 서버에서 서빙 중이면 상대경로 사용 가능
var _isSameOrigin = (location.protocol === 'http:' && (location.hostname === '127.0.0.1' || location.hostname === 'localhost'));

async function checkLocalProxy() {
    // same-origin이면 이미 프록시 위에서 동작 중
    if (_isSameOrigin) { _localProxyAvailable = true; return true; }
    if (_localProxyAvailable !== null) return _localProxyAvailable;
    try {
        var ctrl = new AbortController();
        var t = setTimeout(function() { ctrl.abort(); }, 2000);
        var resp = await fetch(LOCAL_PROXY + '/health', { signal: ctrl.signal });
        clearTimeout(t);
        if (resp.ok) {
            _localProxyAvailable = true;
            return true;
        }
    } catch (e) {}
    _localProxyAvailable = false;
    return false;
}

function isValidXML(text) {
    if (!text || typeof text !== 'string') return false;
    var trimmed = text.trim();
    // XML 선언 또는 XML 태그로 시작하고, HTML/script 아닌 경우
    if (trimmed.startsWith('<?xml')) return true;
    if (trimmed.startsWith('<') && !trimmed.toLowerCase().includes('<html') && !trimmed.toLowerCase().includes('<script')) return true;
    return false;
}

async function fetchWithProxy(url) {
    var lastError = '';

    // 1순위: 로컬 프록시 (DLP 우회)
    var hasLocal = await checkLocalProxy();
    if (hasLocal) {
        try {
            var proxyBase = _isSameOrigin ? '' : LOCAL_PROXY;
            var localUrl = proxyBase + '/proxy?url=' + encodeURIComponent(url);
            var ctrl1 = new AbortController();
            var t1 = setTimeout(function() { ctrl1.abort(); }, 12000);
            var resp1 = await fetch(localUrl, { signal: ctrl1.signal });
            clearTimeout(t1);
            if (resp1.ok) {
                var text1 = await resp1.text();
                if (isValidXML(text1)) return text1;
                console.warn('로컬 프록시: XML이 아닌 응답');
            } else {
                var errBody = await resp1.text().catch(function() { return ''; });
                console.warn('로컬 프록시 HTTP', resp1.status, errBody);
            }
        } catch (e) {
            lastError = '로컬 프록시 실패: ' + e.message;
            console.warn(lastError);
        }
    }

    // 2순위: 직접 호출 (law.go.kr은 CORS 허용)
    try {
        var ctrl2 = new AbortController();
        var t2 = setTimeout(function() { ctrl2.abort(); }, 10000);
        var directResp = await fetch(url, { method: 'GET', signal: ctrl2.signal });
        clearTimeout(t2);
        if (directResp.ok) {
            var directText = await directResp.text();
            if (isValidXML(directText)) return directText;
            console.warn('직접 호출 응답이 XML이 아님 (DLP 차단 가능):', directText.substring(0, 100));
            lastError = '직접 호출: DLP/방화벽에 의해 차단됨';
        } else {
            lastError = '직접 호출: HTTP ' + directResp.status;
        }
    } catch (e) {
        lastError = '직접 호출 실패: ' + e.message;
        console.warn(lastError);
    }

    // 3순위: 외부 CORS 프록시
    for (var i = 0; i < CORS_PROXIES.length; i++) {
        var proxy = CORS_PROXIES[i];
        if (!proxy.healthy) continue;
        try {
            var proxyUrl = proxy.url + encodeURIComponent(url);
            var ctrl3 = new AbortController();
            var t3 = setTimeout(function() { ctrl3.abort(); }, 8000);
            var resp3 = await fetch(proxyUrl, { signal: ctrl3.signal });
            clearTimeout(t3);
            if (resp3.ok) {
                var text3 = await resp3.text();
                if (proxy.type === 'allorigins' && text3.startsWith('{')) {
                    try { text3 = JSON.parse(text3).contents || text3; } catch (pe) {}
                }
                if (isValidXML(text3)) return text3;
                proxy.healthy = false;
                continue;
            }
        } catch (err) {
            proxy.healthy = false;
        }
    }

    // 모든 방법 실패
    if (!hasLocal) {
        throw new Error(lastError + '\n\n해결 방법: start_proxy.bat을 실행하여 로컬 프록시 서버를 시작하세요.');
    }
    throw new Error(lastError || '모든 API 호출 시도 실패');
}

