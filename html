        '- **조례(자치법규) 검색이 필요한 경우**: 용적률, 건폐율, 주차장 기준, 건축 허가, 도시계획 등 지자체별로 기준이 다른 사항은 반드시 "ordin" 키워드에 구체적 조례명을 포함하세요.\n' +
        '  예: "서울특별시 도시계획 조례", "경기도 건축 조례" 등\n\n' +
        '참고 법령 데이터베이스:\n' + LAW_DATABASE.getLawContext() + '\n\n' +
        '반드시 아래 JSON 형식으로만 응답하세요 (다른 텍스트 없이 JSON만):\n' +
        '```json\n' +
        '{\n' +
        '  "draftAnswer": "마크다운 형식의 드래프트 답변 (법령명·조문번호 명시, 500~1500자)",\n' +
        '  "citations": [\n' +
        '    {"type": "law", "name": "법령명", "article": "조번호", "content": "핵심 내용 요약"},\n' +
        '    {"type": "ordin", "name": "조례명", "article": "조번호", "content": "핵심 내용 요약"},\n' +
        '    {"type": "prec", "caseNum": "판례번호", "content": "판시사항 요약"}\n' +
        '  ],\n' +
        '  "searchStrategy": {\n' +
        '    "lawTitle": ["정확한 법령명1", "법령명2"],\n' +
        '    "lawContent": ["본문검색 키워드1", "키워드2"],\n' +
        '    "admrul": ["행정규칙 키워드1"],\n' +
        '    "ordin": ["조례 키워드1"],\n' +
        '    "precContent": ["판례 본문검색 키워드1", "키워드2"],\n' +
        '    "precRefLaw": ["참조법령명1"],\n' +
        '    "expc": ["질의회신 키워드1"]\n' +
        '  },\n' +
        '  "needsDetc": false,\n' +
        '  "needsDecc": false,\n' +
        '  "detcKeywords": ["헌재 검색어"],\n' +
        '  "deccKeywords": ["행정심판 검색어"],\n' +
        '  "followUpQuestions": ["후속질문1", "후속질문2", "후속질문3"],\n' +
        '  "relevantLaws": ["법령명1"],\n' +
        '  "specificArticles": [{"law": "법령명", "article": "조번호"}]\n' +
        '}\n' +
        '```';

    var response = await callAI(systemPrompt, question);

    // JSON 추출 (마크다운 코드블록 제거)
    var jsonStr = response.replace(/```json\s*/g, '').replace(/```\s*/g, '').trim();

    // JSON 부분만 추출
    var jsonMatch = jsonStr.match(/\{[\s\S]*\}/);
    if (jsonMatch) {
        jsonStr = jsonMatch[0];
    }

    try {
        var parsed = JSON.parse(jsonStr);
        // 필수 필드 기본값 보장
        parsed.draftAnswer = parsed.draftAnswer || '';
        parsed.citations = parsed.citations || [];
        parsed.searchStrategy = parsed.searchStrategy || {};
        parsed.searchStrategy.lawTitle = parsed.searchStrategy.lawTitle || [];
        parsed.searchStrategy.lawContent = parsed.searchStrategy.lawContent || [];
        parsed.searchStrategy.admrul = parsed.searchStrategy.admrul || [];
        parsed.searchStrategy.ordin = parsed.searchStrategy.ordin || [];
        parsed.searchStrategy.precContent = parsed.searchStrategy.precContent || [];
        parsed.searchStrategy.precRefLaw = parsed.searchStrategy.precRefLaw || [];
        parsed.searchStrategy.expc = parsed.searchStrategy.expc || [];
        parsed.needsDetc = parsed.needsDetc || false;
        parsed.needsDecc = parsed.needsDecc || false;
        parsed.detcKeywords = parsed.detcKeywords || [];
        parsed.deccKeywords = parsed.deccKeywords || [];
        parsed.followUpQuestions = parsed.followUpQuestions || [];
        parsed.relevantLaws = parsed.relevantLaws || parsed.searchStrategy.lawTitle || [];
        parsed.specificArticles = parsed.specificArticles || [];
