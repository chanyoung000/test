// Scroll to source table row
function scrollToSource(num) {
    var tables = document.querySelectorAll('#aiAnswer table');
    for (var i = 0; i < tables.length; i++) {
        var rows = tables[i].querySelectorAll('tr');
        for (var j = 0; j < rows.length; j++) {
            var firstCell = rows[j].querySelector('td');
            if (firstCell && firstCell.textContent.trim().indexOf('[' + num + ']') !== -1) {
                rows[j].style.background = '#fef3c7';
                rows[j].scrollIntoView({ behavior: 'smooth', block: 'center' });
                setTimeout(function(row) { row.style.background = ''; }, 2000, rows[j]);
                return;
            }
        }
    }
}

// Law References
function hideLawRefs() {
    document.getElementById('lawRefsSection').classList.remove('show');
}

function displayLawReferences(lawDataCollection) {
    if (!lawDataCollection || lawDataCollection.length === 0) return;

    var section = document.getElementById('lawRefsSection');
    var cardsContainer = document.getElementById('lawRefsCards');
    cardsContainer.innerHTML = '';

    var totalRefs = 0;
    var seenLaws = {};

    lawDataCollection.forEach(function(item) {
        // 검색 결과 카드
        if (item.searchResults) {
            item.searchResults.forEach(function(sr) {
                if (seenLaws[sr.lawName]) return;
                seenLaws[sr.lawName] = true;
                totalRefs++;

                var card = createLawCard(sr, item.keyword);
                cardsContainer.appendChild(card);
            });
        }

        // 상세 조문 카드
        if (item.lawName && item.articles) {
            if (seenLaws[item.lawName]) return;
            seenLaws[item.lawName] = true;
            totalRefs++;

            var detailCard = createDetailLawCard(item);
            cardsContainer.appendChild(detailCard);
        }
    });

    if (totalRefs > 0) {
        document.getElementById('lawRefsCount').textContent = totalRefs;
        section.classList.add('show');
    }
}

function createLawCard(searchResult, keyword) {
    var card = document.createElement('div');
    card.className = 'law-card';

    var typeClass = searchResult.lawType === 'admrul' ? 'admrul' : (searchResult.lawType === 'ordin' ? 'ordin' : 'law');
    var typeLabel = searchResult.lawType === 'admrul' ? '행정규칙' : (searchResult.lawType === 'ordin' ? '자치법규' : '법령');

    card.innerHTML =
        '<div class="law-card-header" onclick="toggleLawCard(this)">' +
            '<span class="law-card-title">' + escapeHtml(searchResult.lawName) + '</span>' +
            '<div class="law-card-badges">' +
                '<span class="law-type-badge ' + typeClass + '">' + typeLabel + '</span>' +
                '<span class="law-card-toggle">\u25BC</span>' +
            '</div>' +
        '</div>' +
        '<div class="law-card-body">' +
            '<div class="law-article">' +
                '<div class="law-article-title">검색 키워드: ' + escapeHtml(keyword) + '</div>' +
                '<div>공포일: ' + escapeHtml(searchResult.promDate || '미상') + ' | 시행일: ' + escapeHtml(searchResult.enforceDate || '미상') + '</div>' +
            '</div>' +
        '</div>' +
        '<div class="law-card-footer">' +
            '<a class="law-link" href="https://www.law.go.kr/법령/' + encodeURIComponent(searchResult.lawName) + '" target="_blank" rel="noopener">law.go.kr에서 원문 보기 \u2192</a>' +
        '</div>';

    return card;
}

function createDetailLawCard(detail) {
    var card = document.createElement('div');
    card.className = 'law-card';

    var articlesHtml = '';
    detail.articles.forEach(function(art) {
        articlesHtml +=
            '<div class="law-article">' +
                '<div class="law-article-title">제' + escapeHtml(art.articleNum) + '조' +
                (art.articleTitle ? ' (' + escapeHtml(art.articleTitle) + ')' : '') +
                '</div>' +
                '<div>' + escapeHtml(art.articleContent || '(내용 없음)').substring(0, 500) +
                (art.articleContent && art.articleContent.length > 500 ? '...' : '') +
                '</div>' +
            '</div>';
    });

    card.innerHTML =
        '<div class="law-card-header" onclick="toggleLawCard(this)">' +
            '<span class="law-card-title">' + escapeHtml(detail.lawName) + '</span>' +
            '<div class="law-card-badges">' +
                '<span class="law-type-badge law">법령 상세</span>' +
                '<span class="law-card-toggle">\u25BC</span>' +
            '</div>' +
        '</div>' +
        '<div class="law-card-body show">' + articlesHtml + '</div>' +
        '<div class="law-card-footer">' +
            '<a class="law-link" href="https://www.law.go.kr/법령/' + encodeURIComponent(detail.lawName) + '" target="_blank" rel="noopener">law.go.kr에서 원문 보기 \u2192</a>' +
        '</div>';

    return card;
}

function toggleLawCard(headerEl) {
    var body = headerEl.nextElementSibling;
    var toggle = headerEl.querySelector('.law-card-toggle');
    body.classList.toggle('show');
    toggle.classList.toggle('open');
}

// Error
function showError(message, question) {
    var responseSection = document.getElementById('responseSection');
    responseSection.classList.add('show');
    document.getElementById('responseMeta').textContent = '';
    document.getElementById('aiAnswer').innerHTML =
        '<div class="error-box">' +
            '<strong>오류가 발생했습니다</strong><br>' +
            escapeHtml(message) +
            '<br><button class="retry-btn" onclick="performSearch()">다시 시도</button>' +
        '</div>';
}

// Search History
function getHistory() {
    try {
        return JSON.parse(localStorage.getItem('cl_search_history') || '[]');
    } catch (e) {
        return [];
    }
}

function saveToHistory(question) {
    var history = getHistory();
    // 중복 제거
    history = history.filter(function(item) { return item.q !== question; });
    // 앞에 추가
    history.unshift({ q: question, date: formatDate() });
    // 최대 20건
    if (history.length > 20) history = history.slice(0, 20);
    localStorage.setItem('cl_search_history', JSON.stringify(history));
    renderSearchHistory();
}

function clearHistory() {
    localStorage.removeItem('cl_search_history');
    renderSearchHistory();
    showToast('검색 기록이 삭제되었습니다');
}

function renderSearchHistory() {
    var history = getHistory();
    var list = document.getElementById('historyList');

    if (history.length === 0) {
        list.innerHTML = '<div class="history-empty">검색 기록이 없습니다.</div>';
        return;
    }

    list.innerHTML = history.map(function(item) {
        return '<div class="history-item" onclick="searchFromHistory(\'' + escapeHtml(item.q).replace(/'/g, "\\'") + '\')">' +
            '<span class="q-text">' + escapeHtml(item.q) + '</span>' +
            '<span class="q-date">' + escapeHtml(item.date) + '</span>' +
        '</div>';
    }).join('');
}

function searchFromHistory(question) {
    document.getElementById('searchInput').value = question;
    performSearch();
}

// Category Chips
function renderCategoryChips() {
    var container = document.getElementById('categoryChips');
    container.innerHTML = LAW_DATABASE.categories.map(function(cat) {
        return '<button class="chip" data-category="' + cat.id + '" onclick="selectCategory(\'' + cat.id + '\')">' +
            '<span class="chip-icon">' + cat.icon + '</span>' + escapeHtml(cat.name) +
        '</button>';
    }).join('');
}

function selectCategory(catId) {
    // 토글 활성 상태
    var chips = document.querySelectorAll('.chip');
    chips.forEach(function(c) {
        if (c.dataset.category === catId) {
            c.classList.toggle('active');
        } else {
            c.classList.remove('active');
        }
    });

    // 예시 질문 + 법령 목록 표시
    var cat = LAW_DATABASE.categories.find(function(c) { return c.id === catId; });
    var activeChip = document.querySelector('.chip[data-category="' + catId + '"].active');
    var exContainer = document.getElementById('exampleQuestions');
    var lawListEl = document.getElementById('categoryLawList');

    if (activeChip && cat) {
        // 예시 질문
        if (cat.examples) {
            exContainer.innerHTML = '<span style="font-size:12px;color:#9ca3af;margin-right:4px;">예시:</span>' +
                cat.examples.map(function(ex) {
                    return '<button class="example-q" onclick="setExampleQuestion(\'' + escapeHtml(ex).replace(/'/g, "\\'") + '\')">' + escapeHtml(ex) + '</button>';
                }).join('');
        }
        // 해당 카테고리 법령 목록
        lawListEl.innerHTML = '<span style="font-size:12px;color:#6b7280;margin-right:6px;">포함 법령:</span>' +
            cat.laws.map(function(law) {
                return '<span class="category-law-item" onclick="setExampleQuestion(\'' + escapeHtml(law.shortName).replace(/'/g, "\\'") + '\')">' + escapeHtml(law.shortName) + '</span>';
            }).join('');
        lawListEl.classList.add('show');
    } else {
        renderDefaultExamples();
        lawListEl.classList.remove('show');
    }
}

function setExampleQuestion(q) {
    document.getElementById('searchInput').value = q;
    document.getElementById('searchInput').focus();
}

function renderDefaultExamples() {
    var examples = [
        '임금체불 시 사용자 처벌은?',
        '전세보증금 미반환 시 대처 방법은?',
        '양도소득세 비과세 요건은?',
        '사기죄 공소시효 기간은?'
    ];
    var container = document.getElementById('exampleQuestions');
    container.innerHTML = '<span style="font-size:12px;color:#9ca3af;margin-right:4px;">예시:</span>' +
        examples.map(function(ex) {
            return '<button class="example-q" onclick="setExampleQuestion(\'' + escapeHtml(ex).replace(/'/g, "\\'") + '\')">' + escapeHtml(ex) + '</button>';
        }).join('');
}

// ===== Event Listeners =====
document.addEventListener('DOMContentLoaded', function() {
    // Enter 키 검색
    document.getElementById('searchInput').addEventListener('keypress', function(e) {
        if (e.key === 'Enter') handleSearch();
    });

    // 모달 외부 클릭 닫기
    document.getElementById('settingsModal').addEventListener('click', function(e) {
        if (e.target === this) closeSettings();
    });

    // ESC 키
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') closeSettings();
    });

    // 초기 렌더링
    renderCategoryChips();
    renderDefaultExamples();
    renderSearchHistory();
    updateUsageDisplay();

    // 로컬 프록시 확인 (백그라운드)
    checkLocalProxy().then(function() {
        var hdr = document.getElementById('headerProxyStatus');
        if (hdr) {
            if (_localProxyAvailable) {
                hdr.textContent = 'Proxy ON';
                hdr.style.color = '#86efac';
            } else {
                hdr.textContent = 'Proxy OFF';
                hdr.style.color = '#fca5a5';
            }
        }
    });

    // 이전 평문 키 자동 마이그레이션
    if (localStorage.getItem('cl_gemini_key') && !localStorage.getItem('cl_gemini_key_enc')) {
        loadKeyDecrypted('gemini');
    }
    if (localStorage.getItem('cl_law_oc') && !localStorage.getItem('cl_law_oc_enc')) {
        loadKeyDecrypted('law');
    }
    // config.js 키를 암호화 저장 (첫 로드 시 1회)
    if (!hasKeySaved('law') && window.__CL_CONFIG && window.__CL_CONFIG.LAW_OC) {
        saveKeyEncrypted('law', window.__CL_CONFIG.LAW_OC);
    }
    if (!hasKeySaved('gemini') && window.__CL_CONFIG && window.__CL_CONFIG.GEMINI_KEY) {
        saveKeyEncrypted('gemini', window.__CL_CONFIG.GEMINI_KEY);
    }

    // API 키 상태 확인
    var hasLaw = !!getLawOC();
    var hasGemini = !!getGeminiKey();
    if (!hasGemini && !hasLaw) {
        showToast('설정에서 API 키를 입력해주세요 (우측 상단)', 4000);
    } else if (!hasGemini && hasLaw) {
        showToast('법령 직접검색 가능! AI 검색은 Gemini 키 필요', 3000);
    } else if (hasGemini && hasLaw) {
        showToast('API 키 로드 완료', 1500);
    }
});
</script>



