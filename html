// 검색 모드 관리
// =====================================================================
var currentSearchMode = 'ai'; // 'ai' | 'direct'

function switchSearchMode(mode) {
    currentSearchMode = mode;
    document.querySelectorAll('.search-tab').forEach(function(tab) {
        tab.classList.toggle('active', tab.dataset.mode === mode);
    });
    var input = document.getElementById('searchInput');
    var typeOpts = document.getElementById('searchTypeOptions');
    if (mode === 'ai') {
        input.placeholder = '예: 임금체불 시 사용자 처벌은?, 전세보증금 반환 절차는?';
        typeOpts.style.display = 'none';
    } else {
        input.placeholder = '법령명 또는 키워드 (예: 건축법, 근로기준법, 하도급)';
        typeOpts.style.display = 'block';
    }
}

function handleSearch() {
    if (currentSearchMode === 'ai') {
        performSearch();
    } else {
        performDirectSearch();
    }
}

// 법령 직접검색 (Gemini 없이)
async function performDirectSearch() {
    var keyword = document.getElementById('searchInput').value.trim();
    if (!keyword) {
        showToast('검색어를 입력해주세요');
        document.getElementById('searchInput').focus();
        return;
    }

    var lawOC = getLawOC();
    if (!lawOC) {
        showToast('법제처 API 키가 필요합니다. 설정에서 입력하세요.', 3500);
        openSettings();
        return;
    }

    document.getElementById('btnSearch').disabled = true;
    // 다른 결과 영역 숨기기
    hideResponse();
    hideLawRefs();
    document.getElementById('directResults').classList.remove('show');

    try {
        // 선택된 유형별 동시 검색
        var promises = [];
        var types = [];
        var directOpts = { search: 2, display: 20 };
        if (document.getElementById('chkLaw').checked) { promises.push(searchLaw(keyword, 'law', 1, directOpts).catch(function() { return { totalCount: 0, items: [] }; })); types.push('law'); }
        if (document.getElementById('chkAdmrul').checked) { promises.push(searchLaw(keyword, 'admrul', 1, directOpts).catch(function() { return { totalCount: 0, items: [] }; })); types.push('admrul'); }
        if (document.getElementById('chkOrdin').checked) { promises.push(searchLaw(keyword, 'ordin', 1, directOpts).catch(function() { return { totalCount: 0, items: [] }; })); types.push('ordin'); }
        if (document.getElementById('chkPrec').checked) { promises.push(searchPrec(keyword, 1, { search: 2 }).catch(function() { return { totalCount: 0, items: [] }; })); types.push('prec'); }
        if (document.getElementById('chkExpc').checked) { promises.push(searchExpc(keyword, 1, { search: 2 }).catch(function() { return { totalCount: 0, items: [] }; })); types.push('expc'); }

        if (promises.length === 0) {
            showToast('검색 유형을 하나 이상 선택하세요');
            document.getElementById('btnSearch').disabled = false;
            return;
        }

        var results = await Promise.all(promises);
        var allItems = [];
        var totalCount = 0;
        results.forEach(function(r, idx) {
            totalCount += r.totalCount;
            r.items.forEach(function(item) {
                if (!item.resultType) item.resultType = types[idx];
                if (!item.lawType) item.lawType = types[idx];
                allItems.push(item);
            });
        });

        displayDirectResults(allItems, totalCount, keyword);
        saveToHistory(keyword);
    } catch (err) {
        showToast('검색 실패: ' + err.message, 3500);
    } finally {
        document.getElementById('btnSearch').disabled = false;
    }
}

function displayDirectResults(items, totalCount, keyword) {
    var section = document.getElementById('directResults');
    var stats = document.getElementById('directResultsStats');
    var list = document.getElementById('directResultsList');

    if (items.length === 0) {
        stats.textContent = '"' + keyword + '" 검색 결과가 없습니다.';
        list.innerHTML = '';
        section.classList.add('show');
        return;
    }

    var countParts = [];
    var lawC = items.filter(function(i) { return i.resultType === 'law'; }).length;
    var admC = items.filter(function(i) { return i.resultType === 'admrul'; }).length;
    var ordC = items.filter(function(i) { return i.resultType === 'ordin'; }).length;
    var precC = items.filter(function(i) { return i.resultType === 'prec'; }).length;
    var expcC = items.filter(function(i) { return i.resultType === 'expc'; }).length;
    if (lawC) countParts.push('법령 ' + lawC);
    if (admC) countParts.push('행정규칙 ' + admC);
    if (ordC) countParts.push('자치법규 ' + ordC);
