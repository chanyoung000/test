// Progress
function showProgress() {
    document.getElementById('progressSection').classList.add('show');
    [1, 2, 3, 4].forEach(function(i) {
        document.getElementById('step' + i).className = 'step-circle';
        document.getElementById('stepLabel' + i).className = 'step-label';
    });
    document.getElementById('progressFill').style.width = '0';
}

function hideProgress() {
    document.getElementById('progressSection').classList.remove('show');
}

function updateProgress(step, text) {
    // 이전 스텝 완료 표시
    for (var i = 1; i < step; i++) {
        document.getElementById('step' + i).className = 'step-circle done';
        document.getElementById('step' + i).innerHTML = '\u2713';
        document.getElementById('stepLabel' + i).className = 'step-label';
    }
    // 현재 스텝 활성화
    document.getElementById('step' + step).className = 'step-circle active';
    document.getElementById('stepLabel' + step).className = 'step-label active';

    // 프로그레스 바
    var percent = Math.round((step / 4) * 100);
    document.getElementById('progressFill').style.width = percent + '%';

    // 텍스트
    document.getElementById('progressText').innerHTML = '<span class="spinner"></span> ' + escapeHtml(text);
}

// Response
function hideResponse() {
    document.getElementById('responseSection').classList.remove('show');
}

function displayAnswer(answer, question, searchStats) {
    document.getElementById('responseSection').classList.add('show');

    // 대시보드 배지
    var dashboardHtml = '';
    if (searchStats) {
        var badges = [];
        if (searchStats.law > 0) badges.push('<span class="summary-badge"><span class="badge-icon">📜</span>법령 <span class="badge-count">' + searchStats.law + '건</span></span>');
        if (searchStats.admrul > 0) badges.push('<span class="summary-badge"><span class="badge-icon">📋</span>행정규칙 <span class="badge-count">' + searchStats.admrul + '건</span></span>');
        if (searchStats.ordin > 0) badges.push('<span class="summary-badge"><span class="badge-icon">🏛</span>조례 <span class="badge-count">' + searchStats.ordin + '건</span></span>');
        if (searchStats.prec > 0) badges.push('<span class="summary-badge"><span class="badge-icon">⚖</span>판례 <span class="badge-count">' + searchStats.prec + '건</span></span>');
        if (searchStats.expc > 0) badges.push('<span class="summary-badge"><span class="badge-icon">📋</span>질의회신 <span class="badge-count">' + searchStats.expc + '건</span></span>');
        if (searchStats.detc > 0) badges.push('<span class="summary-badge"><span class="badge-icon">🏛</span>헌재결정 <span class="badge-count">' + searchStats.detc + '건</span></span>');
        if (searchStats.decc > 0) badges.push('<span class="summary-badge"><span class="badge-icon">📑</span>행정심판 <span class="badge-count">' + searchStats.decc + '건</span></span>');
        if (badges.length > 0) {
            dashboardHtml = '<div class="result-summary-dashboard">' + badges.join('') + '</div>';
        }
    }

    document.getElementById('aiAnswer').innerHTML = dashboardHtml + renderMarkdown(answer);
    document.getElementById('responseMeta').textContent = formatDate();
}

