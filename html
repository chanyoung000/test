function escapeHtml(str) {
    if (!str) return '';
    const d = document.createElement('div');
    d.textContent = str;
    return d.innerHTML;
}

function showToast(msg, duration) {
    duration = duration || 2500;
    const el = document.getElementById('toast');
    el.textContent = msg;
    el.classList.add('show');
    setTimeout(function() { el.classList.remove('show'); }, duration);
}

function formatDate(date) {
    if (!date) date = new Date();
    var y = date.getFullYear();
    var m = String(date.getMonth() + 1).padStart(2, '0');
    var d = String(date.getDate()).padStart(2, '0');
    var h = String(date.getHours()).padStart(2, '0');
    var mi = String(date.getMinutes()).padStart(2, '0');
    return y + '-' + m + '-' + d + ' ' + h + ':' + mi;
}

function renderMarkdown(text) {
    if (!text) return '';
    var html = escapeHtml(text);

    // Headers
    html = html.replace(/^#### (.+)$/gm, '<h4>$1</h4>');
    html = html.replace(/^### (.+)$/gm, '<h3>$1</h3>');
    html = html.replace(/^## (.+)$/gm, '<h2>$1</h2>');
    html = html.replace(/^# (.+)$/gm, '<h1>$1</h1>');

    // Bold and italic
    html = html.replace(/\*\*\*(.+?)\*\*\*/g, '<strong><em>$1</em></strong>');
    html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
    html = html.replace(/\*(.+?)\*/g, '<em>$1</em>');

    // Inline code
    html = html.replace(/`([^`]+)`/g, '<code>$1</code>');

    // Blockquote
    html = html.replace(/^&gt; (.+)$/gm, '<blockquote>$1</blockquote>');

    // Tables
    html = html.replace(/^(\|.+\|)\n(\|[-| :]+\|)\n((?:\|.+\|\n?)*)/gm, function(match, headerRow, sepRow, bodyRows) {
        var headers = headerRow.split('|').filter(function(c) { return c.trim(); });
        var rows = bodyRows.trim().split('\n');
        var table = '<table><thead><tr>';
        headers.forEach(function(h) { table += '<th>' + h.trim() + '</th>'; });
        table += '</tr></thead><tbody>';
        rows.forEach(function(row) {
            var cells = row.split('|').filter(function(c) { return c.trim(); });
            table += '<tr>';
            cells.forEach(function(c) { table += '<td>' + c.trim() + '</td>'; });
            table += '</tr>';
        });
        table += '</tbody></table>';
        return table;
    });

    // Unordered list
    html = html.replace(/^[\-\*] (.+)$/gm, '<li>$1</li>');
    html = html.replace(/((?:<li>.+<\/li>\n?)+)/g, '<ul>$1</ul>');

    // Ordered list
    html = html.replace(/^\d+\. (.+)$/gm, '<li>$1</li>');

    // Links
    html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>');

    // Paragraphs
    html = html.replace(/\n{2,}/g, '</p><p>');
    html = html.replace(/\n/g, '<br>');

    // Clean up
    html = '<p>' + html + '</p>';
    html = html.replace(/<p>\s*<(h[1-4]|ul|ol|table|blockquote)/g, '<$1');
    html = html.replace(/<\/(h[1-4]|ul|ol|table|blockquote)>\s*<\/p>/g, '</$1>');
    html = html.replace(/<p>\s*<\/p>/g, '');

    // Inline citations: [1], [2] → clickable superscript
    html = html.replace(/\[(\d{1,2})\]/g, function(match, num) {
        return '<a class="citation-ref" onclick="scrollToSource(' + num + ')" title="출처 [' + num + ']로 이동">[' + num + ']</a>';
    });

    // Verification badges: [검증완료] → green, [미검증] → yellow
    html = html.replace(/\[검증완료\]/g, '<span class="verified-badge verified">✓ 검증완료</span>');
    html = html.replace(/\[미검증\]/g, '<span class="verified-badge unverified">⚠ 미검증</span>');

    return html;
}

function parseXML(xmlText) {
    if (!xmlText || typeof xmlText !== 'string') {
        throw new Error('XML 응답이 비어있습니다.');
    }
    // HTML 차단 페이지 감지 (DLP/방화벽 차단)
    if (xmlText.includes('<html') || xmlText.includes('<script')) {
        throw new Error('API 응답이 차단되었습니다 (HTML 반환). 네트워크 환경을 확인하세요.');
    }
    var parser = new DOMParser();
    var doc = parser.parseFromString(xmlText, 'text/xml');
    var parseError = doc.querySelector('parsererror');
    if (parseError) {
        console.error('XML 파싱 실패. 응답 앞부분:', xmlText.substring(0, 200));
        throw new Error('XML 파싱 오류 (응답: ' + xmlText.substring(0, 60) + '...)');
    }
    return doc;
}

function getXMLText(el, tag) {
    if (!el) return '';
    var node = el.getElementsByTagName(tag)[0];
    return node ? (node.textContent || '').trim() : '';
}

function getXMLAll(el, tag) {
    if (!el) return [];
    return Array.from(el.getElementsByTagName(tag));
}

// XOR decode
function _dk(e, s) {
    var d = atob(e);
    var r = '';
    for (var i = 0; i < d.length; i++) {
        r += String.fromCharCode(d.charCodeAt(i) ^ s.charCodeAt(i % s.length));
    }
    return r;
}

// XOR encode (for creating obfuscated keys)
function _ek(plainText, seed) {
    var r = '';
    for (var i = 0; i < plainText.length; i++) {
        r += String.fromCharCode(plainText.charCodeAt(i) ^ seed.charCodeAt(i % seed.length));
    }
    return btoa(r);
}


