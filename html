function getCacheKey(prefix, params) {
    return 'cl_cache_' + prefix + '_' + Object.values(params).join('_');
}

function getCache(key) {
    try {
        var data = sessionStorage.getItem(key);
        if (data) return JSON.parse(data);
    } catch (e) {}
    return null;
}

function setCache(key, value) {
    try {
        sessionStorage.setItem(key, JSON.stringify(value));
    } catch (e) {
        // sessionStorage 용량 초과 시 무시
    }
}

// 법령 검색 (lawSearch.do)
async function searchLaw(keyword, target, pageNum, options) {
    target = target || 'law';
    pageNum = pageNum || 1;
    options = options || {};

    // 캐시 확인 — search, display 포함
    var cacheKey = getCacheKey('search', {
        keyword: keyword, target: target, page: pageNum,
        search: options.search || 1, display: options.display || 10,
        jo: options.JO || ''
    });
    var cached = getCache(cacheKey);
    if (cached) return cached;

    var oc = getLawOC();
    if (!oc) throw new Error('법제처 API 인증키(OC)가 설정되지 않았습니다.');

    var params = new URLSearchParams({
        OC: oc,
        target: target,
        type: 'XML',
        query: keyword,
        display: String(options.display || 10),
        page: String(pageNum),
        sort: 'efdes'  // 시행일 내림차순 → 최신 시행 법령 우선
    });
    if (options.search) params.set('search', String(options.search));
    if (options.JO) params.set('JO', options.JO);

    var url = 'https://www.law.go.kr/DRF/lawSearch.do?' + params.toString();
    var xmlText = await fetchWithProxy(url);
    var doc = parseXML(xmlText);

    var totalCount = parseInt(getXMLText(doc, 'totalCnt') || '0', 10);
    var items = [];

    // API 응답 태그: <law>, <admrul>, <ordin> 또는 한글 태그
    var tagNames = target === 'law' ? ['law', '법령'] :
                   target === 'admrul' ? ['admrul', '행정규칙'] :
                   ['ordin', '자치법규'];
    var lawNodes = [];
    for (var t = 0; t < tagNames.length; t++) {
        lawNodes = getXMLAll(doc, tagNames[t]);
        if (lawNodes.length > 0) break;
    }

    lawNodes.forEach(function(node) {
        var historyCode = getXMLText(node, '현행연혁코드') || getXMLText(node, '법령구분') || '';
        items.push({
            lawName: getXMLText(node, '법령명한글') || getXMLText(node, '행정규칙명') || getXMLText(node, '자치법규명') || getXMLText(node, '법령명'),
            mst: getXMLText(node, '법령일련번호') || getXMLText(node, '자치법규일련번호') || getXMLText(node, '행정규칙일련번호') || getXMLText(node, '법령MST') || getXMLText(node, 'MST'),
            lawId: getXMLText(node, '법령ID') || getXMLText(node, '자치법규ID') || getXMLText(node, '행정규칙ID'),
            promDate: getXMLText(node, '공포일자') || getXMLText(node, '발령일자'),
            enforceDate: getXMLText(node, '시행일자'),
            lawType: target,
            historyCode: historyCode,   // '현행', '연혁' 등
            isCurrent: historyCode === '' || historyCode === '현행' || historyCode.indexOf('현행') !== -1
        });
    });

    // 동일 법령명의 여러 버전이 있으면 현행 우선, 그 다음 최신 시행일 우선
    var bestByName = {};
    items.forEach(function(item) {
        var key = item.lawName;
        if (!key) return;
        var existing = bestByName[key];
        if (!existing) {
            bestByName[key] = item;
        } else {
            // 현행이 우선
            if (item.isCurrent && !existing.isCurrent) {
                bestByName[key] = item;
            } else if (item.isCurrent === existing.isCurrent) {
                // 같은 상태면 시행일이 더 최근인 것 우선
                if ((item.enforceDate || '') > (existing.enforceDate || '')) {
                    bestByName[key] = item;
                }
            }
        }
    });
    var dedupedItems = [];
    var seen = {};
    items.forEach(function(item) {
        var key = item.lawName;
        if (!key || seen[key]) return;
        // bestByName에서 선택된 최적 버전 사용
        if (bestByName[key]) {
            dedupedItems.push(bestByName[key]);
            seen[key] = true;
        }
    });

    var result = { totalCount: totalCount, items: dedupedItems };
    setCache(cacheKey, result);
    return result;
}

// 법령/행정규칙/자치법규 상세 조회 (lawService.do)
async function getLawDetail(mstOrId, target) {
    target = target || 'law';
    // 캐시 확인
    var cacheKey = getCacheKey('detail', { mst: mstOrId, target: target });
    var cached = getCache(cacheKey);
    if (cached) return cached;

    var oc = getLawOC();
    if (!oc) throw new Error('법제처 API 인증키(OC)가 설정되지 않았습니다.');

    // MST로 먼저 시도, 조문이 없으면 ID로 재시도
    var doc = null;
    var attempts = [
        { MST: mstOrId },
        { ID: mstOrId }
    ];
    for (var ai = 0; ai < attempts.length; ai++) {
        var params = new URLSearchParams({
            OC: oc,
            target: target,
            type: 'XML'
        });
        Object.keys(attempts[ai]).forEach(function(k) { params.set(k, attempts[ai][k]); });
        var url = 'https://www.law.go.kr/DRF/lawService.do?' + params.toString();
        try {
            var xmlText = await fetchWithProxy(url);
            doc = parseXML(xmlText);
            var testNodes = getXMLAll(doc, '조문단위');
            if (testNodes.length > 0) break; // 조문이 있으면 성공
        } catch (e) {
            if (ai === attempts.length - 1) throw e;
        }
    }

    var lawName = getXMLText(doc, '법령명_한글') || getXMLText(doc, '법령명한글') ||
                  getXMLText(doc, '자치법규명') || getXMLText(doc, '행정규칙명');
    var articles = [];
    var articleNodes = getXMLAll(doc, '조문단위');

    articleNodes.forEach(function(node) {
        articles.push({
            articleNum: getXMLText(node, '조문번호'),
            articleTitle: getXMLText(node, '조문제목'),
            articleContent: getXMLText(node, '조문내용'),
            articleKey: getXMLText(node, '조문키')
        });
    });

    var detailResult = {
        lawName: lawName,
        mst: mstOrId,
        articles: articles,
        totalArticles: articles.length
    };
    setCache(cacheKey, detailResult);
    return detailResult;
}

// 특정 조문 가져오기
async function getLawArticle(mstOrId, articleNum, target) {
    var detail = await getLawDetail(mstOrId, target);
    if (!detail || !detail.articles) return null;

    var numStr = String(articleNum).replace(/[^0-9]/g, '');
    var found = detail.articles.filter(function(a) {
        return a.articleNum && a.articleNum.replace(/[^0-9]/g, '') === numStr;
    });

    return found.length > 0 ? found[0] : null;
}

