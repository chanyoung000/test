        parsed.searchKeywords = [].concat(parsed.searchStrategy.lawTitle, parsed.searchStrategy.lawContent).filter(Boolean);
        if (parsed.searchKeywords.length === 0) parsed.searchKeywords = [question];
        return parsed;
    } catch (e) {
        console.warn('AI 분석 JSON 파싱 실패, 기본값 사용:', e.message);
        return {
            draftAnswer: '',
            citations: [],
            searchStrategy: {
                lawTitle: [], lawContent: [question], admrul: [], ordin: [],
                precContent: [question], precRefLaw: [], expc: [question]
            },
            needsDetc: false,
            needsDecc: false,
            detcKeywords: [],
            deccKeywords: [],
            followUpQuestions: [],
            relevantLaws: [],
            searchKeywords: [question],
            specificArticles: [],
            reasoning: 'JSON 파싱 실패로 원본 질문으로 검색합니다.'
        };
    }
}

// Phase 3: AI 초안 + API 데이터 통합 검증 답변
async function synthesizeAnswer(question, lawDataCollection, analysisResult) {
    var lawContext = '';
    var precContext = '';
    var expcContext = '';
    var admrulContext = '';
    var ordinContext = '';
    var detcContext = '';
    var deccContext = '';

    lawDataCollection.forEach(function(item) {
        // 법령 조문
        if (item.articles && item.articles.length > 0 && !item.resultType) {
            lawContext += '\n\n--- ' + item.lawName + ' ---\n';
            item.articles.forEach(function(art) {
                if (art.articleTitle || art.articleContent) {
                    lawContext += '제' + art.articleNum + '조';
                    if (art.articleTitle) lawContext += ' (' + art.articleTitle + ')';
                    lawContext += '\n' + (art.articleContent || '(내용 없음)') + '\n';
                }
            });
        }
        // 검색 결과 목록
        else if (item.searchResults) {
            var targetCtx = item.searchTarget === 'admrul' ? 'admrul' :
                           item.searchTarget === 'ordin' ? 'ordin' : 'law';
            var line = '\n\n--- 검색 결과: ' + item.keyword + ' ---\n';
            item.searchResults.forEach(function(sr) {
                line += '- ' + sr.lawName + ' (시행: ' + (sr.enforceDate || '미상') + ')\n';
            });
            if (targetCtx === 'admrul') admrulContext += line;
            else if (targetCtx === 'ordin') ordinContext += line;
            else lawContext += line;
        }
        // 판례
        else if (item.resultType === 'prec') {
            precContext += '\n\n--- 판례: ' + (item.caseName || item.caseNum || '') + ' (' + (item.court || '') + ' ' + (item.date || '') + ') ---\n';
            if (item.summary) precContext += '[판시사항] ' + item.summary.replace(/<br\/>/g, '\n').substring(0, 1500) + '\n';
            if (item.holding) precContext += '[판결요지] ' + item.holding.replace(/<br\/>/g, '\n').substring(0, 1500) + '\n';
            if (item.refArticles) precContext += '[참조조문] ' + item.refArticles.replace(/<br\/>/g, ', ') + '\n';
        }
        // 질의회신
        else if (item.resultType === 'expc') {
            expcContext += '\n\n--- 질의회신: ' + (item.title || '') + ' (' + (item.replyOrg || '') + ' ' + (item.date || '') + ') ---\n';
            if (item.question) expcContext += '[질의요지] ' + item.question.substring(0, 1000) + '\n';
            if (item.answer) expcContext += '[회답] ' + item.answer.substring(0, 1000) + '\n';
            if (item.reason) expcContext += '[이유] ' + item.reason.substring(0, 1000) + '\n';
        }
        // 헌재결정례
        else if (item.resultType === 'detc') {
            detcContext += '\n\n--- 헌재결정례: ' + (item.caseName || item.caseNum || '') + ' (' + (item.date || '') + ') ---\n';
            if (item.summary) detcContext += '[결정요지] ' + item.summary.replace(/<br\/>/g, '\n').substring(0, 1500) + '\n';
            if (item.holding) detcContext += '[결정요지상세] ' + item.holding.replace(/<br\/>/g, '\n').substring(0, 1500) + '\n';
        }
        // 행정심판재결례
        else if (item.resultType === 'decc') {
            deccContext += '\n\n--- 행정심판재결례: ' + (item.caseName || item.caseNum || '') + ' (' + (item.court || '') + ' ' + (item.date || '') + ') ---\n';
            if (item.summary) deccContext += '[재결요지] ' + item.summary.replace(/<br\/>/g, '\n').substring(0, 1500) + '\n';
        }
    });

    var allContext = '';
    if (lawContext) allContext += '\n\n[법령 데이터]\n' + lawContext;
    if (admrulContext) allContext += '\n\n[행정규칙 데이터]\n' + admrulContext;
    if (ordinContext) allContext += '\n\n[조례 데이터]\n' + ordinContext;
    if (precContext) allContext += '\n\n[판례 데이터]\n' + precContext;
    if (expcContext) allContext += '\n\n[질의회신 데이터]\n' + expcContext;
    if (detcContext) allContext += '\n\n[헌재결정례 데이터]\n' + detcContext;
    if (deccContext) allContext += '\n\n[행정심판재결례 데이터]\n' + deccContext;

    var draftSection = '';
    if (analysisResult && analysisResult.draftAnswer) {
        draftSection = '\n\n## Phase 1 AI 초안 답변 (검증 대상)\n' + analysisResult.draftAnswer + '\n\n' +
            '## Phase 1 인용 목록\n' + JSON.stringify(analysisResult.citations || [], null, 2) + '\n';
    }

    var systemPrompt = '당신은 한국 법령 분석 AI입니다.\n\n' +
        '## 핵심 임무\n' +
        'Phase 1에서 생성한 AI 초안 답변을 아래 API 검색 데이터로 **검증하고 보강**하세요.\n\n' +
        '## 검증 규칙\n' +
        '1. AI 초안에서 인용한 법령·조문이 API 데이터에서 **확인되면** → `[검증완료]`로 표시\n' +
        '2. AI 초안에서 인용한 내용이 API 데이터에 **없으면** → `[미검증]`으로 표시\n' +
        '3. API 데이터에서 **AI 초안에 없는 중요 정보**를 발견하면 → "추가 발견" 섹션에 추가\n' +
        '4. AI 초안과 API 데이터가 **모순**되면 → API 데이터를 우선하되 차이점 명시\n\n' +
        '## 답변 구조 (마크다운)\n' +
        '### 핵심 답변\n' +
        '질문에 대한 직접적 답변 (2~3문장). 인라인 각주 [1], [2] 사용.\n\n' +
        '### 상세 분석\n' +
        '관련 법령 조문 분석. 각 인용에 [검증완료] 또는 [미검증] 표시.\n\n' +
        '### 판례 (해당 시)\n' +
        '관련 판례 요약. 판례번호 명시.\n\n' +
        '### 행정해석 (해당 시)\n' +
        '질의회신/유권해석 내용.\n\n' +
        '### 행정규칙/조례 (해당 시)\n' +
        '행정규칙·조례 내용.\n\n' +
        '### 추가 발견\n' +
        'API 검색에서 추가로 발견된 관련 정보.\n\n' +
        '### 출처\n' +
        '| 번호 | 유형 | 출처명 | 검증 |\n' +
        '|------|------|--------|------|\n' +
        '| [1] | 법령 | 법령명 제N조 | 검증완료/미검증 |\n\n' +
        '- 해당되지 않는 섹션은 생략하세요.\n' +
        '- 한국어로 답변하세요.\n' +
        draftSection +
        '\n## API 검색 데이터 (검증용)\n' +
        (allContext || '(검색된 데이터 없음)');

    return callAI(systemPrompt, question);
}


