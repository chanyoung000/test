// =====================================================================
// API 사용량 관리 (무료 한도 90% 제한)
// =====================================================================
// Gemini 무료 한도 (모델 폴백 체인 사용 시 가장 보수적인 기준 적용)
// gemini-2.0-flash: 15 RPM, 1500 RPD (주력)
// gemini-2.0-flash-lite: 30 RPM, 1500 RPD (1차 폴백)
// gemini-2.5-flash: 10 RPM, 25 RPD (최후 폴백)
// 다른 프로그램 사용분 여유를 위해 일일 한도의 90%만 사용
var GEMINI_LIMITS = {
    RPD: 1500,          // 무료 일일 요청 한도 (보수적 기준)
    RPM: 15,            // 무료 분당 요청 한도 (보수적 기준)
    SAFE_RATIO: 0.9     // 90%까지만 사용 (나머지 10%는 다른 프로그램 여유분)
};
var DAILY_LIMIT = Math.floor(GEMINI_LIMITS.RPD * GEMINI_LIMITS.SAFE_RATIO); // 1350

function _getTodayKey() {
    return new Date().toISOString().slice(0, 10); // "YYYY-MM-DD"
}

function getDailyUsage() {
    try {
        var data = JSON.parse(localStorage.getItem('cl_gemini_usage') || '{}');
        if (data.date !== _getTodayKey()) {
            // 날짜가 바뀌면 리셋
            return { date: _getTodayKey(), calls: 0, minuteLog: [] };
        }
        return data;
    } catch (e) {
        return { date: _getTodayKey(), calls: 0, minuteLog: [] };
    }
}

function recordAPICall() {
    var usage = getDailyUsage();
    usage.calls++;
    usage.minuteLog = usage.minuteLog || [];
    usage.minuteLog.push(Date.now());
    // 최근 2분 이내 기록만 유지 (메모리 절약)
    var twoMinAgo = Date.now() - 120000;
    usage.minuteLog = usage.minuteLog.filter(function(t) { return t > twoMinAgo; });
    localStorage.setItem('cl_gemini_usage', JSON.stringify(usage));
    updateUsageDisplay();
}

function canMakeAPICall() {
    var usage = getDailyUsage();

    // 일일 한도 체크
    if (usage.calls >= DAILY_LIMIT) {
        return {
            ok: false,
            reason: '오늘 무료 API 사용 한도(' + DAILY_LIMIT + '회)에 도달했습니다.\n자정(KST) 이후 초기화됩니다.',
            remaining: 0
        };
    }

    // 분당 한도 체크
    var oneMinAgo = Date.now() - 60000;
    var recentCalls = (usage.minuteLog || []).filter(function(t) { return t > oneMinAgo; });
    if (recentCalls.length >= GEMINI_LIMITS.RPM) {
        var waitSec = Math.ceil((recentCalls[0] + 60000 - Date.now()) / 1000);
        return {
            ok: false,
            reason: '분당 요청 한도(' + GEMINI_LIMITS.RPM + '회)에 도달했습니다.\n' + waitSec + '초 후 다시 시도하세요.',
            remaining: DAILY_LIMIT - usage.calls
        };
    }

    return { ok: true, remaining: DAILY_LIMIT - usage.calls };
}

function updateUsageDisplay() {
    var badge = document.getElementById('usageBadge');
    if (!badge) return;

    var usage = getDailyUsage();
    var remaining = DAILY_LIMIT - usage.calls;
    var ratio = usage.calls / DAILY_LIMIT;

    badge.textContent = '오늘 ' + usage.calls + '/' + DAILY_LIMIT + '회';
    badge.title = '오늘 Gemini API 사용: ' + usage.calls + '회 / 한도 ' + DAILY_LIMIT + '회 (잔여 ' + remaining + '회)';

    badge.className = 'usage-badge';
    if (ratio >= 0.9) {
        badge.className = 'usage-badge danger';
    } else if (ratio >= 0.7) {
        badge.className = 'usage-badge warning';
    }
}

